{
  "name": "@gud/bench",
  "version": "2.0.0-next.0",
  "description": "A powerful and elegant benchmarking tool for JavaScript and TypeScript.",
  "license": "Apache-2.0",
  "author": "Ryan Goree (https://github.com/ryangoree)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryangoree/gud-bench.git"
  },
  "sideEffects": false,
  "type": "module",
  "bin": {
    "bench": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "tsc --build --clean tsconfig.cli.json tsconfig.lib.json",
    "build": "tsc --build tsconfig.cli.json tsconfig.lib.json",
    "watch": "tsc --build tsconfig.cli.json tsconfig.lib.json --watch",
    "bench": "node dist/cli.js",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && biome check --diagnostic-level error . ",
    "check:package": "publint",
    "fix": "biome check --diagnostic-level error . --write",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@gud/cli": "^1.0.0-beta.7",
    "@gud/cli-menu": "^1.0.0-beta.5",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "publint": "^0.3.21",
    "typescript": "^7.0.2"
  },
  "imports": {
    "#src/*": "./dist/*.js"
  },
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
